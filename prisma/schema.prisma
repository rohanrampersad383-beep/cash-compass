generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  currencyCode       String              @default("TTD")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bills              Bill[]
  budgets            Budget[]
  categories         Category[]
  expenses           Expense[]
  incomes            Income[]
  savingsGoals       SavingsGoal[]
  sessions           Session[]
  transactions       Transaction[]
  uploadedStatements UploadedStatement[]
}

model Session {
  id          String   @id @default(cuid())
  sessionHash String   @unique
  userId      String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id           String        @id @default(cuid())
  name         String
  color        String
  icon         String
  type         CategoryType
  userId       String
  createdAt    DateTime      @default(now())
  bills        Bill[]
  budgets      Budget[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses     Expense[]
  incomes      Income[]
  transactions Transaction[]

  @@unique([userId, name, type])
  @@index([userId, type])
}

model Transaction {
  id          String             @id @default(cuid())
  title       String
  amount      Decimal            @db.Decimal(12, 2)
  date        DateTime
  kind        TransactionKind
  notes       String?
  paymentType PaymentType?
  isRecurring Boolean            @default(false)
  userId      String
  categoryId  String?
  statementId String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  category    Category?          @relation(fields: [categoryId], references: [id])
  statement   UploadedStatement? @relation(fields: [statementId], references: [id])
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, kind])
}

model Income {
  id          String    @id @default(cuid())
  source      String
  amount      Decimal   @db.Decimal(12, 2)
  date        DateTime
  notes       String?
  isRecurring Boolean   @default(false)
  frequency   Frequency @default(ONCE)
  userId      String
  categoryId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Category? @relation(fields: [categoryId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Expense {
  id          String      @id @default(cuid())
  merchant    String
  amount      Decimal     @db.Decimal(12, 2)
  date        DateTime
  notes       String?
  paymentType PaymentType @default(CARD)
  isRecurring Boolean     @default(false)
  frequency   Frequency   @default(ONCE)
  userId      String
  categoryId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category?   @relation(fields: [categoryId], references: [id])
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Bill {
  id         String     @id @default(cuid())
  name       String
  amount     Decimal    @db.Decimal(12, 2)
  dueDate    DateTime
  frequency  Frequency  @default(MONTHLY)
  status     BillStatus @default(UNPAID)
  userId     String
  categoryId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  category   Category?  @relation(fields: [categoryId], references: [id])
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@index([userId, status])
}

model Budget {
  id          String    @id @default(cuid())
  name        String
  limitAmount Decimal   @db.Decimal(12, 2)
  period      Frequency @default(MONTHLY)
  userId      String
  categoryId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Category? @relation(fields: [categoryId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, categoryId])
}

model SavingsGoal {
  id            String   @id @default(cuid())
  name          String
  targetAmount  Decimal  @db.Decimal(12, 2)
  currentAmount Decimal  @db.Decimal(12, 2)
  targetDate    DateTime
  color         String   @default("#22c55e")
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, targetDate])
}

model UploadedStatement {
  id            String        @id @default(cuid())
  fileName      String
  rowCount      Int
  importedCount Int           @default(0)
  uploadedAt    DateTime      @default(now())
  userId        String
  transactions  Transaction[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, uploadedAt])
}

enum CategoryType {
  INCOME
  EXPENSE
  BILL
}

enum TransactionKind {
  INCOME
  EXPENSE
}

enum Frequency {
  ONCE
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PaymentType {
  CARD
  CASH
  BANK_TRANSFER
  DIGITAL_WALLET
  OTHER
}

enum BillStatus {
  PAID
  UNPAID
}
