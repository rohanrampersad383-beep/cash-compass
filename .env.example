# Pooled Neon connection string used by the Next.js app and seed runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-example-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Optional direct Neon connection string used by Prisma CLI migrations/introspection.
# If omitted, Prisma CLI falls back to DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@ep-example.REGION.aws.neon.tech/neondb?sslmode=require"

# Optional Upstash Redis REST credentials for distributed production rate limiting.
# If omitted, the app falls back to an in-memory limiter for local development.
UPSTASH_REDIS_REST_URL="https://example.upstash.io"
UPSTASH_REDIS_REST_TOKEN="upstash-example-token"

# Optional app URL used to build password reset and email verification links.
# In production, set this to your canonical deployed URL.
APP_URL=

# Optional email sender and Resend API key for password reset and email verification.
# If omitted in development, auth links are logged to the server console for testing.
EMAIL_FROM=
RESEND_API_KEY=
