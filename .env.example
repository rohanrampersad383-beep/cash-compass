# Pooled Neon connection string used by the Next.js app and seed runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-example-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Optional direct Neon connection string used by Prisma CLI migrations/introspection.
# If omitted, Prisma CLI falls back to DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@ep-example.REGION.aws.neon.tech/neondb?sslmode=require"
